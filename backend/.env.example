# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Groq AI Configuration (for AI Assistant - Fast & Free Alternative)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# MarzPay Payment Gateway (Unified Mobile Money - MTN & Airtel)
MARZPAY_API_KEY=your-marzpay-api-key
MARZPAY_API_SECRET=your-marzpay-api-secret
MARZPAY_API_URL=https://wallet.wearemarz.com/api/v1
MARZPAY_CALLBACK_URL=https://your-domain.com/api/v1/payments/marzpay/callback
APP_URL=https://your-domain.com

# MTN Mobile Money API (Legacy - prefer MarzPay)
MTN_API_KEY=your-mtn-api-key
MTN_API_SECRET=your-mtn-api-secret
MTN_ENVIRONMENT=sandbox
MTN_CALLBACK_URL=https://your-domain.com/api/v1/payments/mtn/callback
MTN_SUBSCRIPTION_KEY=your-subscription-key

# Airtel Money API (Legacy - prefer MarzPay)
AIRTEL_API_KEY=your-airtel-api-key
AIRTEL_API_SECRET=your-airtel-api-secret
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_URL=https://your-domain.com/api/v1/payments/airtel/callback

# Card Payment (Stripe/Flutterwave)
FLUTTERWAVE_PUBLIC_KEY=your-flw-public-key
FLUTTERWAVE_SECRET_KEY=your-flw-secret-key
FLUTTERWAVE_ENCRYPTION_KEY=your-flw-encryption-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Firebase (for Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# SMS Configuration (for OTP)
SMS_SERVICE=egosms
# EGO SMS (Comms SDK / API)
EGO_SMS_API_USERNAME=your-ego-api-username
EGO_SMS_API_KEY=your-ego-api-key
EGO_SMS_SENDER_ID=AgriSupply
EGO_SMS_USE_SANDBOX=true
EGO_SMS_TEST_NUMBERS=
EGO_SMS_FORCE_TEST_MODE=false
EGO_SMS_API_URL=

# Legacy EgoSMS (fallback)
EGOSMS_API_URL=https://your-egosms-endpoint
EGOSMS_USERNAME=your-username
EGOSMS_PASSWORD=your-password
EGOSMS_SENDER_ID=AgriSupply

# SMS Templates
SMS_PAYMENT_SUCCESS=Thank you {name}! Your payment of UGX {amount} for order #{orderNumber} was received. -AgriSupply
SMS_PAYMENT_FAILED=Sorry {name}, payment of UGX {amount} for order #{orderNumber} failed. Please try again. -AgriSupply
